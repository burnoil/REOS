; REOS v0.3 — Shared material and geometry tokens

[Variables]
; Global spacing
Unit=4
GapSmall=6
Gap=10
GapLarge=16
PanelPadding=12
DisplayPadding=14

; Construction dimensions
FrameThickness=3
ModuleRadius=4
DisplayRadius=10
PlateHeight=28
FastenerSize=3

; Material effects
RaisedShadowSize=4
RaisedHighlightAlpha=90
InsetShadowSize=5
GlassHighlightAlpha=28

; Reusable Shape meter fragments
; Rainmeter does not support true style inheritance for Shape strings,
; so modules consume these values while retaining their own dimensions.
StructureStroke=#ConsoleSeam#
ModuleFill=#ModuleFace#
ModuleStroke=#ModuleEdgeDark#
PlateFill=#PlateFace#
PlateStroke=#PlateEdge#
DisplayBezelFill=#CRTBezel#
DisplayGlassFill=#CRTGlass#
DisplayGlassStroke=#CRTGlassEdge#
